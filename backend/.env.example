NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hm_attendance?schema=public
REDIS_URL=redis://localhost:6379
DB_CONNECT_MAX_RETRIES=8
DB_RETRY_DELAY_MS=1500
DB_CONNECT_TIMEOUT_MS=5000
REDIS_CONNECT_MAX_RETRIES=8
REDIS_RETRY_DELAY_MS=1000
REDIS_SOCKET_CONNECT_TIMEOUT_MS=5000
SHUTDOWN_TIMEOUT_MS=10000

JWT_ACCESS_SECRET=replace-with-a-strong-access-secret
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
